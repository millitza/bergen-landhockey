---
const email = "styret@bergenlandhockey.no";
const orgNumber = "934 345 355";
const socials = [
  { name: "Instagram", url: "https://www.instagram.com/bergen_landhockey/", icon: "/images/instagram_logo.png" },
  { name: "Facebook",  url: "https://www.facebook.com/BergenLandhockey/",   icon: "/images/facebook_logo.png" },
];
const copyright = `© ${new Date().getFullYear()} Bergen Landhockeyklubb · All rights reserved`;
---

<footer id="contact">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/images/logo.svg" alt="Bergen Landhockeyklubb" />
      <div class="footer-contact">
        <p>Contact us</p>
        <a href={`mailto:${email}`}>{email}</a>
        <p class="footer-org">Organisasjonsnummer: {orgNumber}</p>
      </div>
    </div>
    <div class="footer-socials">
      {socials.map(s => (
        <a class="social-link" href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.name}>
          <img src={s.icon} alt={s.name} />
        </a>
      ))}
    </div>
  </div>
  <p class="footer-copy">{copyright}</p>
</footer>
